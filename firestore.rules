rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - lastSeen: timestamp (optional)
    //   - status: string (optional)
    //   - encryptionEnabled: bool (optional) - E2EE status
    //   - publicKey: string (optional) - RSA Public Key Base64
    //
    // Collection: conversations
    // Document ID: {conversationId}
    // Fields:
    //   - participants: list (required) - UIDs of users in the chat
    //   - lastMessage: map (optional) - { text, senderId, timestamp }
    //   - unreadCount: map (optional) - { uid: count }
    //
    // Sub-collection: conversations/{conversationId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - text: string (required) - Ciphertext if encrypted, else plain text
    //   - timestamp: timestamp (required)
    //   - isEncrypted: bool (required)
    //   - isGroupMessage: bool (optional)
    //   - iv: string (optional) - Required if isEncrypted is true
    //   - encryptedKey: string (optional) - Required if isEncrypted is true (except for group messages)
    //
    // Sub-collection: conversations/{conversationId}/keys
    // Document ID: {userId}
    // Fields:
    //   - key: string (required) - Group key encrypted with user's RSA public key
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kolesbalazs93@gmail.com" && request.auth.token.email_verified == true));
    }

    function isParticipant(participants) {
      return isAuthenticated() && request.auth.uid in participants;
    }

    function isConversationParticipant(conversationId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('publicKey' in data) || (data.publicKey is string && data.publicKey.size() < 1000)) &&
             (!('encryptionEnabled' in data) || data.encryptionEnabled is bool);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'timestamp', 'isEncrypted']) &&
             data.senderId == request.auth.uid &&
             data.timestamp is timestamp &&
             data.isEncrypted is bool &&
             (
               (data.isEncrypted == false && data.keys().hasAll(['text']) && data.text is string) || 
               (data.isEncrypted == true && data.keys().hasAll(['iv']) && data.iv is string && 
                 (
                   (data.keys().hasAll(['isGroupMessage']) && data.isGroupMessage == true) || 
                   (data.keys().hasAll(['encryptedKey']) && data.encryptedKey is string)
                 ) &&
                 (data.keys().hasAll(['text']) || data.keys().hasAll(['fileUrl']))
               )
             );
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['participants']) &&
             data.participants is list && data.participants.size() >= 2 && data.participants.size() <= 10;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Public profiles and public keys are readable by authenticated users
      allow read: if isAuthenticated();
      // Only the owner can create/update their profile
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /conversations/{conversationId} {
      // Only participants can see the conversation metadata
      allow read: if isParticipant(resource.data.participants);
      // Any authenticated user can start a conversation if they are a participant
      allow create: if isAuthenticated() && isParticipant(request.resource.data.participants) && isValidConversation(request.resource.data);
      // Participants can update metadata (e.g., lastMessage, unreadCount)
      allow update: if isParticipant(resource.data.participants) && 
                      request.resource.data.participants == resource.data.participants &&
                      isValidConversation(request.resource.data);

      match /messages/{messageId} {
        // Only participants of the parent conversation can read messages
        allow read: if isConversationParticipant(conversationId);
        // Only participants can send messages
        allow create: if isConversationParticipant(conversationId) && isValidMessage(request.resource.data);
        // Messages are immutable - no update or delete allowed
        allow update, delete: if false;
      }

      match /keys/{userId} {
        // Csak a saját titkosított kulcsát olvashatja a felhasználó
        allow read: if isOwner(userId);
        // Bármely résztvevő írhat kulcsot (pl. csoport létrehozásakor vagy új tag hozzáadásakor)
        allow create, update: if isConversationParticipant(conversationId);
      }
    }
  }
}
